generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String?
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  groupes   GroupeMembre[]

  @@map("users")
}

model Groupe {
  id        Int      @id @default(autoincrement())
  nom       String
  cours     String?
  emoji     String?
  createdAt DateTime @default(now())
  membres   GroupeMembre[]
}

model GroupeMembre {
  id       Int    @id @default(autoincrement())
  userId   Int
  groupeId Int
  user     User   @relation(fields: [userId], references: [id])
  groupe   Groupe @relation(fields: [groupeId], references: [id])
}

model Project {
  id          Int      @id @default(autoincrement())
  nom         String
  description String?
  avancement  Int      @default(0)
  dateLimite  String?
  createdAt   DateTime @default(now())
  taches      Task[]
}

model Task {
  id        Int      @id @default(autoincrement())
  titre     String
  statut    String   @default("todo")
  priorite  String   @default("Moyenne")
  deadline  String? 
  assignee  String?
  projectId Int
  project   Project  @relation(fields: [projectId], references: [id])
  createdAt DateTime @default(now())
}
